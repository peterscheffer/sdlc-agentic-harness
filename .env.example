# SDLC Agentic Harness — environment configuration
# Copy this file to `.env` and fill in your own values. `.env` is gitignored.

# --- LLM providers (set whichever you use) ---
# OpenAI-compatible endpoint (also works for local Ollama via OPENAI_API_BASE)
OPENAI_API_KEY=
OPENAI_API_BASE=http://127.0.0.1:11434/v1

# OpenRouter
OPENROUTER_API_KEY=

# Ollama (local)
OLLAMA_API_KEY=

# --- LangSmith observability (optional) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=sdlc-agentic-harness

# --- Testing ---
# Set to 1 to use a mock LLM instead of real API calls
SDLC_USE_MOCK_LLM=
